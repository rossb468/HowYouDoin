<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	<!-- NSPersistentCloudKitContainer schedules its background sync via
	     BGTaskScheduler using this identifier. It must be listed here or the
	     scheduler rejects the request with
	     "BGSystemTaskSchedulerErrorDomain Code=3". -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.apple.coredata.cloudkit.activity</string>
	</array>
</dict>
</plist>
